# Context Governance — Codex Adapter Configuration
# Bootstrap copies this to .codex/config.toml in your target project.
#
# Authority: docs/plans/2026-03-24-deerflow-inspired-governance-engine-plan.md §6.1
# Format: https://developers.openai.com/codex/config-reference

# --- Sandbox ---
# workspace-write: agent can read/edit within workspace, run local commands.
# Governance protection is enforced via AGENTS.md instructions + pre-commit hooks,
# not sandbox file-level restrictions (Codex sandbox does not support per-file read-only).
sandbox_mode = "workspace-write"

# --- MCP Governance Server ---
[mcp_servers.governance]
command = "python3"
args = ["governance-mcp-server/server.py"]
startup_timeout_sec = 10.0
tool_timeout_sec = 60.0
enabled = true
required = false

# --- Project Docs ---
# Codex reads AGENTS.md from project root automatically.
# Skills are discovered from .agents/skills/ directory.
project_doc_max_bytes = 65536
