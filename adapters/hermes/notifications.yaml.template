# Context Governance — Hermes Notification Configuration
# Configures push notifications for governance events via Hermes messaging gateway.
#
# Authority: Phase A integration — governance event notifications.
# Notifications are INFORMATIONAL ONLY. The canonical state is always in .governance/.
#
# Prerequisites:
#   1. Hermes messaging gateway configured for your platform(s)
#   2. At least one platform adapter enabled in ~/.hermes/config.yaml
#
# Setup:
#   1. Copy this file to your project as adapters/hermes/notifications.yaml
#   2. Uncomment and configure the platforms you want to use
#   3. The governance-check skill reads this config to determine notification targets

# ──────────────────────────────────────────────────────────
# Platform Configuration
# ──────────────────────────────────────────────────────────
# Uncomment the platforms you want governance notifications sent to.
# Each platform must be configured in Hermes gateway first.

platforms:
  # slack:
  #   enabled: true
  #   channel: "#governance-alerts"
  #   # Only send on these event types (omit to send all):
  #   events:
  #     - escalation_created
